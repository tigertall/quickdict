{
  "app-id": "io.github.tigertall.QuickDict",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "branch": "stable",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "quickdict",
  "finish-args": [
    "--socket=wayland",
    "--socket=fallback-x11",
    "--share=ipc",
    "--device=dri",
    "--share=network"
  ],
 "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/quickdict/cargo",
      "CARGO_NET_OFFLINE": "true"
    }
  },
  "modules": [
    {
      "name": "quickdict",
      "buildsystem": "meson",
      "config-opts": [
        "--buildtype=release"
      ],
      "make-args": [
        "-v"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "./" 
        },
        "cargo-sources.json"
      ]
    }
  ]
}
